{
    "name": "web-app",
    "version": "0.1.0",
    "type": "module",
    "private": true,
    "packageManager": "pnpm@10.14.0",
    "engines": {
        "node": "^22.0.0"
    },
    "scripts": {
        "dev": "next dev",
        "build": "next build",
