        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "lint-staged": "^17.0.8",
        "prettier": "^3.9.4",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "schema-dts": "^2.0.0",
        "tailwindcss": "^4",
        "typescript": "^5",
        "vitest": "^4.1.10"
