        "clsx": "^2.1.1",
        "leaflet": "^1.9.4",
        "lucide-react": "^1.23.0",
        "motion": "^12.42.2",
        "next": "16.2.10",
        "next-intl": "^4.13.1",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-hook-form": "^7.81.0",
        "react-leaflet": "^5.0.0",
        "server-only": "^0.0.1",
        "tailwind-merge": "^3.6.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.2.0",
        "@commitlint/config-conventional": "^21.2.0",
        "@playwright/test": "^1.61.1",
